# Copy to `.env`. Do not commit `.env`.
# PostgreSQL (required). Same URL for ERP + customer portal on Streamlit Cloud (secrets).
DATABASE_URL=
# Optional: disable auto sslmode=require for remote URLs (local Docker etc.)
# DATABASE_SSLMODE=disable
# DATABASE_CONNECT_TIMEOUT=30
# Template names live in `wa_templates.py` (e.g. account_creation_confirmation_3).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# WHATSAPP_DISABLE=1
