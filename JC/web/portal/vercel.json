{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jc-api-production.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://jc-api-production.up.railway.app/health"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
