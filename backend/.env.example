DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Supabase (Dashboard → Project Settings → Database):
# - "Direct connection" host db.<ref>.supabase.co port 5432 — good for local dev / long-lived Railway.
# - "Session pooler" or "Transaction pooler" (port 6543) — better for many short-lived connections; use the URI Supabase shows.
# App adds sslmode=require automatically when the host contains "supabase" and sslmode is not already set.
# Offline: DATABASE_URL=sqlite:///./dev.db
# ./scripts/run-local-stack.sh forces sqlite dev.db unless LOCAL_STACK_SKIP_SQLITE=1
# Table name `portal_customers` — avoids clashing with an existing `customers` table.
JWT_SECRET=change-me-long-random
ADMIN_API_KEY=change-me-admin-key
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v22.0
WHATSAPP_DISABLE=0
# Meta template name for customer portal order booked (default: order_booking)
WHATSAPP_ORDER_BOOKED_TEMPLATE_NAME=
CUSTOMER_PORTAL_URL_BUTTON_SUFFIX=

# Supabase Storage (S3 API) — catalog images under product_images/
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
