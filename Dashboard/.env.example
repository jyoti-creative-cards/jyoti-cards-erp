# Copy to `.env`. Do not commit `.env`.
# PostgreSQL — paste Supabase connection string (same for ERP + portal; Streamlit Cloud secrets).
DATABASE_URL=
# Set to 1 when Postgres schema already exists and you want no CREATE/ALTER on startup (Cloud).
# DATABASE_SKIP_DDL=1
# Template names live in `wa_templates.py` (e.g. account_creation_confirmation_3).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# WHATSAPP_DISABLE=1
